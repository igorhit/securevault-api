{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=securevault.db"
  },
  "Jwt": {
    "Issuer": "SecureVaultAPI",
    "Audience": "SecureVaultClients"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "GeneralRules": [
      {
        "Endpoint": "POST:/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/auth/register",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 20
      }
    ]
  },
  "AllowedHosts": "*"
}
